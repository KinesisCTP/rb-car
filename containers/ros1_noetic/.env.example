# Copy this file to .env if you want to override defaults.

# Leave this unset to mount the repository root as the workspace.
# ROS1_WS=/home/student/rb-car_ws

# Local testing, where this container runs roscore:
ROS_MASTER_URI=http://localhost:11311
ROS_IP=127.0.0.1

# Robot mode example:
# ROS_MASTER_URI=http://192.168.1.50:11311
# ROS_IP=192.168.68.59

ROS_IMAGE=local/kinesis-rb-car-noetic:desktop
CONTAINER_NAME=kinesis_rb_car_noetic
CONTAINER_WORKSPACE=/home/ros/rb-car_ws
